<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#41D7EB"
    tools:context=".MainScreen">

    <TextView
        android:id="@+id/textView4"
        android:layout_width="363dp"
        android:layout_height="65dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView5" />

    <TextView
        android:id="@+id/textView5"
        android:layout_width="337dp"
        android:layout_height="51dp"
        android:layout_marginStart="37dp"
        android:layout_marginTop="6dp"
        android:text="Enter The Current Day Below:"
        android:textColor="@color/black"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnGoToDetails"
        android:layout_width="147dp"
        android:layout_height="61dp"
        android:layout_marginStart="23dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/black"
        android:text="Detail Views "
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="1dp"
        app:layout_constraintStart_toEndOf="@+id/btnCalculateAverage"
        app:layout_constraintTop_toBottomOf="@+id/txtAverageResult" />

    <Button
        android:id="@+id/btnCalculateAverage"
        android:layout_width="199dp"
        android:layout_height="61dp"
        android:layout_marginStart="17dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/black"
        android:text="Calculate The Average"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="1dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtAverageResult" />

    <TextView
        android:id="@+id/txtAverageResult"
        android:layout_width="370dp"
        android:layout_height="199dp"
        android:layout_marginStart="17dp"
        android:layout_marginTop="18dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnSaveDay" />

    <Button
        android:id="@+id/btnSaveDay"
        android:layout_width="123dp"
        android:layout_height="54dp"
        android:layout_marginStart="17dp"
        android:layout_marginTop="34dp"
        android:backgroundTint="#FFC107"
        android:text="Save Day"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="1dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView9" />

    <Button
        android:id="@+id/btnClearData"
        android:layout_width="133dp"
        android:layout_height="55dp"
        android:layout_marginStart="114dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="#FFC107"
        android:text="Clear Data"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="1dp"
        app:layout_constraintStart_toEndOf="@+id/btnSaveDay"
        app:layout_constraintTop_toBottomOf="@+id/edtCondition" />

    <EditText
        android:id="@+id/edtMinTemp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="77dp"
        android:layout_marginTop="13dp"
        android:ems="10"
        android:inputType="text"
        app:layout_constraintStart_toEndOf="@+id/textView7"
        app:layout_constraintTop_toBottomOf="@+id/textView4" />

    <EditText
        android:id="@+id/edtMaxTemp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="80dp"
        android:layout_marginTop="21dp"
        android:ems="10"
        android:inputType="text"
        app:layout_constraintStart_toEndOf="@+id/textView8"
        app:layout_constraintTop_toBottomOf="@+id/edtMinTemp" />

    <EditText
        android:id="@+id/edtCondition"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="31dp"
        android:ems="10"
        android:inputType="text"
        app:layout_constraintStart_toEndOf="@+id/textView9"
        app:layout_constraintTop_toBottomOf="@+id/edtMaxTemp" />

    <TextView
        android:id="@+id/textView7"
        android:layout_width="83dp"
        android:layout_height="30dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="26dp"
        android:text="Min Temp:"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView4" />

    <TextView
        android:id="@+id/textView8"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="17dp"
        android:layout_marginTop="46dp"
        android:text="Max Temp:"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView7" />

    <TextView
        android:id="@+id/textView9"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="7dp"
        android:layout_marginTop="53dp"
        android:text="Weather Condition:"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView8" />
</androidx.constraintlayout.widget.ConstraintLayout>